    <worksheet name='P4_Reorder Alert by Category'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#685842'> Reorder Alert by Category</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='FactInventoryTransactions+ (SmartInventory_DWH)' name='federated.0o3jpeu10ur7xp1cywqy11o6zgvm' />
          </datasources>
          <datasource-dependencies datasource='federated.0o3jpeu10ur7xp1cywqy11o6zgvm'>
            <column caption='P4_Alert' datatype='string' name='[Calculation_0556374219436033]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([CurrentStock]) &lt; SUM([ReorderLevel]) THEN &quot;🚨 Alert&quot;&#13;&#10;ELSE &quot;✅ OK&quot;&#13;&#10;END' />
            </column>
            <column caption='P1_Cost to Revenue Ratio%' datatype='real' default-format='p0.0%' name='[Calculation_0776825447530497]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([LineTotal]) - SUM([ProfitAmount])) / SUM([LineTotal])' />
            </column>
            <column caption='P1_CostRatio Color' datatype='real' name='[Calculation_0776825448468482]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([LineTotal])!=0 &#13;&#10;THEN (SUM([LineTotal])-SUM([ProfitAmount]))/SUM([LineTotal]) &#13;&#10;END' />
            </column>
            <column caption='P1_Gross Margin per Unit' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0776825466753029]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([ProfitAmount]) / SUM([Quantity])' />
            </column>
            <column caption='Current stock' datatype='real' name='[Calculation_0818333728497664]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[CurrentStock]/2' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Current Stock' datatype='integer' name='[CurrentStock]' role='measure' type='quantitative' />
            <column caption='Full Date' datatype='date' name='[FullDate]' role='dimension' type='ordinal' />
            <column caption='Line Total' datatype='real' name='[LineTotal]' role='measure' type='quantitative' />
            <column caption='Profit Amount' datatype='real' name='[ProfitAmount]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
            <column caption='Reorder Level' datatype='integer' name='[ReorderLevel]' role='measure' type='quantitative' />
            <column-instance column='[FullDate]' derivation='Month' name='[mn:FullDate:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0818333728497664]' derivation='Sum' name='[sum:Calculation_0818333728497664:qk]' pivot='key' type='quantitative' />
            <column-instance column='[CurrentStock]' derivation='Sum' name='[sum:CurrentStock:qk]' pivot='key' type='quantitative' />
            <column-instance column='[ReorderLevel]' derivation='Sum' name='[sum:ReorderLevel:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0556374219436033]' derivation='User' name='[usr:Calculation_0556374219436033:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0776825447530497]' derivation='User' name='[usr:Calculation_0776825447530497:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0776825448468482]' derivation='User' name='[usr:Calculation_0776825448468482:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0776825466753029]' derivation='User' name='[usr:Calculation_0776825466753029:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[sum:CurrentStock:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[sum:ReorderLevel:qk]&quot;' />
            </groupfilter>
          </filter>
          <manual-sort column='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[:Measure Names]' direction='ASC'>
