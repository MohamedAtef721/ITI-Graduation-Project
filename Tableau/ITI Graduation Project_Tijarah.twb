    <worksheet name='P5_DivergingMargin'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#685842'>Category Margin vs Target</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='FactInventoryTransactions+ (SmartInventory_DWH)' name='federated.0o3jpeu10ur7xp1cywqy11o6zgvm' />
          </datasources>
          <datasource-dependencies datasource='federated.0o3jpeu10ur7xp1cywqy11o6zgvm'>
            <column caption='P5_Margin Deviation' datatype='real' name='[Calculation_0177317724323848]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([ProfitAmount])/SUM([LineTotal]) - 0.35' />
            </column>
            <column caption='P5_Margin Direction' datatype='string' name='[Calculation_0177317724512265]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0177317724323848] &gt;= 0 THEN &quot;Above Target&quot; ELSE &quot;Below Target&quot; END' />
            </column>
            <column caption='P1_Profit Margin %' datatype='real' default-format='p0.0%' name='[Calculation_0776825501143052]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([ProfitAmount]) / SUM([LineTotal])' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Line Total' datatype='real' name='[LineTotal]' role='measure' type='quantitative' />
            <column caption='Profit Amount' datatype='real' name='[ProfitAmount]' role='measure' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0177317724323848]' derivation='User' name='[usr:Calculation_0177317724323848:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0177317724512265]' derivation='User' name='[usr:Calculation_0177317724512265:nk]' pivot='key' type='nominal' />
