          <alias key='&quot;[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[usr:Calculation_0776825479880713:vtsum:qk]&quot;' value='COGS' />
          <alias key='&quot;[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[usr:Calculation_0776825480040458:vtsum:qk]&quot;' value='GrossProfit' />
        </aliases>
      </column>
      <column caption='Buying Group' datatype='string' name='[BuyingGroup]' role='dimension' type='nominal' />
      <column caption='P1_Quick Table Calculation_1' datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([LineTotal])) - LOOKUP(ZN(SUM([LineTotal])), -1)) / ABS(LOOKUP(ZN(SUM([LineTotal])), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='P1_Quick Table Calculation' datatype='integer' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([LineTotal]))'>
          <table-calc ordering-field='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[Category]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='P3_Avg PO Size' datatype='real' default-format='*#,##0.0 units' name='[Calculation_0161099363627009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([QuantityOrdered]) / COUNTD([PurchaseOrderID])' />
      </column>
      <column caption='P3_PO Frequency' datatype='real' default-format='*0.0 / month' name='[Calculation_0161099364057090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([PurchaseOrderID]) / COUNTD(DATETRUNC(&quot;month&quot;,[FullDate]))' />
      </column>
      <column caption='P3_Cost Efficiency' datatype='real' default-format='*0.00×' name='[Calculation_0161099364667395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([LineTotal])-SUM([ProfitAmount])) / SUM([UnitCostPrice]*[QuantityOrdered])' />
      </column>
      <column caption='P3_Expected Lead Days' datatype='integer' default-format='*0.0 &quot;days&quot;' name='[Calculation_0161099373326341]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [FullDate], [FullDate (DimDate1)])' />
      </column>
      <column caption='P3_Cost CY' datatype='real' name='[Calculation_0161099384958982]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([FullDate]) = {FIXED : MAX(YEAR([FullDate]))} &#13;&#10;THEN [LastCostPrice (DimProduct)] * [QuantityOrdered] &#13;&#10;END' />
      </column>
      <column caption='P3_Cost LY' datatype='real' name='[Calculation_0161099387453447]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([FullDate]) = {FIXED : MAX(YEAR([FullDate]))} - 1 &#13;&#10;THEN [LastCostPrice (DimProduct)] * [QuantityOrdered] &#13;&#10;END' />
      </column>
      <column caption='P3_Cost Variance %' datatype='real' default-format='p0.0%' name='[Calculation_0161099387785224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL(&#13;&#10;  (SUM([Calculation_0161099384958982]) - SUM([Calculation_0161099387453447])) / SUM([Calculation_0161099387453447]), &#13;&#10;  0&#13;&#10;)' />
      </column>
      <column caption='P5_Contribution Margin %' datatype='real' default-format='p0%' name='[Calculation_0177317694152704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([LineTotal]) &#13;&#10; - (SUM([LineTotal])-SUM([ProfitAmount])))&#13;&#10;/ SUM([LineTotal])' />
      </column>
      <column caption='P5_Revenue per $1 of Cost ' datatype='real' default-format='*$0.00 per $1' name='[Calculation_0177317694656513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LineTotal])&#13;&#10;/ (SUM([LineTotal])-SUM([ProfitAmount]))' />
      </column>
      <column caption='P5_Break-Even Revenue' datatype='real' default-format='c&quot;$&quot;#,##0,,.0M;(&quot;$&quot;#,##0,,.0M)' name='[Calculation_0177317710061574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Target Margin = 35%&#13;&#10;// Break-even = COGS / (1 - 0.35)&#13;&#10;(SUM([LineTotal])-SUM([ProfitAmount]))&#13;&#10;/ (1 - 0.35)' />
      </column>
      <column caption='P5_Gross Margin per Unit' datatype='real' default-format='c&quot;$&quot;#,##0.00;(&quot;$&quot;#,##0.00)' name='[Calculation_0177317710618631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ProfitAmount]) / SUM([Quantity])' />
      </column>
      <column caption='P5_Margin Deviation' datatype='real' name='[Calculation_0177317724323848]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ProfitAmount])/SUM([LineTotal]) - 0.35' />
      </column>
      <column caption='P5_Margin Direction' datatype='string' name='[Calculation_0177317724512265]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0177317724323848] &gt;= 0 THEN &quot;Above Target&quot; ELSE &quot;Below Target&quot; END' />
      </column>
      <column caption='P5_Enterprise Jitter' datatype='real' name='[Calculation_0177317728174090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(INDEX() % 10) / 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='P5_Absolute Loss' datatype='real' name='[Calculation_0368357905379328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([ProfitAmount])' />
      </column>
      <column caption='Label Text' datatype='string' name='[Calculation_0368357919047681]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Dashboard&quot;' />
      </column>
      <column caption='P4_Alert' datatype='string' name='[Calculation_0556374219436033]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([CurrentStock]) &lt; SUM([ReorderLevel]) THEN &quot;🚨 Alert&quot;&#13;&#10;ELSE &quot;✅ OK&quot;&#13;&#10;END' />
      </column>
      <column caption='P4_Product Turnover Rate' datatype='real' name='[Calculation_0556374228709378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ZN(SUM([CurrentStock])) = 0 THEN 0 &#13;&#10;ELSE SUM([Quantity]) / SUM([CurrentStock]) &#13;&#10;END' />
      </column>
      <column caption='P4_Stock Value' datatype='real' name='[Calculation_0556374228865027]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([CurrentStock]) * AVG([LastCostPrice])' />
      </column>
      <column caption='P5_Net Profit' datatype='real' default-format='c&quot;$&quot;#,##0,,.0M;(&quot;$&quot;#,##0,,.0M)' name='[Calculation_0556374246887428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ProfitAmount])' />
      </column>
      <column caption='P2_Revenue per Line' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0633614258372608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LineTotal]) / COUNT([SalesKey])' />
      </column>
      <column caption='P2_Weekend Revenue % ' datatype='real' default-format='p0.0%' name='[Calculation_0633614260109313]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [IsWeekend] = TRUE THEN [LineTotal] ELSE 0 END) / SUM([LineTotal])' />
      </column>
      <column caption='P2_Revenue per Salesperson' datatype='real' default-format='c&quot;$&quot;#,##0,,.0M;(&quot;$&quot;#,##0,,.0M)' name='[Calculation_0633614262255618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LineTotal]) / COUNTD([EmployeeKey])' />
      </column>
      <column caption='P2_Customer Repeat Rate ' datatype='real' default-format='p0.0%' name='[Calculation_0633614264827908]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Calculation_0633614266695685] &gt; 1&#13;&#10;  THEN [CustomerKey] END)&#13;&#10;/ COUNTD([CustomerKey])' />
      </column>
      <column caption='P2_CustomerOrderCount' datatype='integer' name='[Calculation_0633614266695685]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [CustomerKey], DATETRUNC(&apos;month&apos;, [FullDate]) : COUNTD([InvoiceID]) }' />
      </column>
      <column caption='P2_Customer Revenue Share %' datatype='real' default-format='p0.00%' name='[Calculation_0633614269222919]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[LineTotal] / { FIXED : SUM([LineTotal]) }' />
      </column>
      <column caption='P3_Total Purchases' datatype='real' default-format='c&quot;$&quot;#,##0,,.0M;(&quot;$&quot;#,##0,,.0M)' name='[Calculation_0757859382112256]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LastCostPrice]) * SUM([QuantityOrdered])' />
      </column>
      <column caption='Rank Direction' datatype='string' name='[Calculation_0761432619659264]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(SUM([LineTotal])) &lt; LOOKUP(RANK(SUM([LineTotal])), -1) THEN &#13;&#10;    &quot;Improved&quot;&#13;&#10;ELSEIF RANK(SUM([LineTotal])) &gt; LOOKUP(RANK(SUM([LineTotal])), -1) THEN &#13;&#10;    &quot;Declined&quot;&#13;&#10;ELSE &#13;&#10;    &quot;Unchanged&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue per Business Day ' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;(&quot;$&quot;#,##0,.00K)' name='[Calculation_0776825441271808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LineTotal]) / COUNTD([FullDate])' />
      </column>
      <column caption='P1_Cost to Revenue Ratio%' datatype='real' default-format='p0.0%' name='[Calculation_0776825447530497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([LineTotal]) - SUM([ProfitAmount])) / SUM([LineTotal])' />
      </column>
      <column caption='P1_CostRatio Color' datatype='real' name='[Calculation_0776825448468482]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([LineTotal])!=0 &#13;&#10;THEN (SUM([LineTotal])-SUM([ProfitAmount]))/SUM([LineTotal]) &#13;&#10;END' />
      </column>
      <column caption='P1_Orders per Customer' datatype='real' default-format='*0.0' name='[Calculation_0776825453498371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([InvoiceID]) / COUNTD([CustomerKey])' />
      </column>
      <column caption='P1_Stock Coverage Days' datatype='real' default-format='*0.0&quot; days&quot;' name='[Calculation_0776825464877060]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([CurrentStock])/2) / (SUM([Quantity]) / COUNTD([FullDate]))' />
      </column>
      <column caption='P1_Gross Margin per Unit' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0776825466753029]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ProfitAmount]) / SUM([Quantity])' />
      </column>
      <column caption='P1_WF_Revenue' datatype='real' default-format='c&quot;$&quot;#,##0,,.00M;(&quot;$&quot;#,##0,,.00M)' name='[Calculation_0776825479708680]' role='measure' type='quantitative' visual-totals='Sum'>
        <calculation class='tableau' formula='SUM([LineTotal])' />
      </column>
      <column caption='P1_WF_COGS' datatype='real' default-format='c&quot;$&quot;#,##0,,.00M;&quot;$&quot;-#,##0,,.00M' name='[Calculation_0776825479880713]' role='measure' type='quantitative' visual-totals='Sum'>
        <calculation class='tableau' formula='-(SUM([LineTotal]) - SUM([ProfitAmount]))' />
      </column>
      <column caption='P1_WF_GrossProfit' datatype='real' default-format='c&quot;$&quot;#,##0,,.00M;(&quot;$&quot;#,##0,,.00M)' name='[Calculation_0776825480040458]' role='measure' type='quantitative' visual-totals='Sum'>
        <calculation class='tableau' formula='SUM([ProfitAmount])' />
      </column>
      <column caption='P1_Profit Margin %' datatype='real' default-format='p0.0%' name='[Calculation_0776825501143052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ProfitAmount]) / SUM([LineTotal])' />
      </column>
      <column caption='P1_Revenue Rank' datatype='integer' name='[Calculation_0776825507389454]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([LineTotal]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='P1_vs Target' datatype='string' name='[Calculation_0776825526239247]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([LineTotal]) &gt;= [Parameters].[Parameter 1] THEN &quot;On Target&quot; &#13;&#10;ELSE &quot;Below Target&quot; &#13;&#10;END' />
      </column>
      <column caption='Current stock' datatype='real' name='[Calculation_0818333728497664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[CurrentStock]/2' />
      </column>
      <column caption='P4_Days of Stock Remaining' datatype='real' default-format='*0.0&quot; days&quot;' name='[Calculation_0878256091983872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([CurrentStock])&#13;&#10;/ (SUM([Quantity]) / 90)' />
      </column>
      <column caption='P4_Stock Value at Risk ' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0878256092946433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [CurrentStock] &lt; [ReorderLevel] THEN ([ReorderLevel]-[CurrentStock])*[LastCostPrice] ELSE 0 END)' />
      </column>
      <column caption='P4_Overstock Value' datatype='real' default-format='c&quot;$&quot;#,##0,,.0M;(&quot;$&quot;#,##0,,.0M)' name='[Calculation_0878256093683714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF ([CurrentStock]/2) &gt; [TargetStockLevel]&#13;&#10;  THEN (([CurrentStock])/2-[TargetStockLevel])&#13;&#10;       *[LastCostPrice]&#13;&#10;  ELSE 0 END)' />
      </column>
      <column caption='P4_Fill Rate %  ' datatype='real' default-format='p0.00%' name='[Calculation_0878256100159491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [CurrentStock] &gt;= [ReorderLevel]&#13;&#10;  THEN 1 END)&#13;&#10;/ COUNTD([ProductKey])' />
      </column>
      <column caption='P4_Index' datatype='integer' name='[Calculation_0878256124121095]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='P4_Stock Status' datatype='string' name='[Calculation_0878256132362249]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([CurrentStock]) = 0 THEN &quot;Out&quot;&#13;&#10;ELSEIF SUM([CurrentStock]) &lt; SUM([ReorderLevel]) THEN &quot;Below&quot;&#13;&#10;ELSEIF SUM([CurrentStock]) &gt; SUM([TargetStockLevel]) THEN &quot;Over&quot;&#13;&#10;ELSE &quot;OK&quot;&#13;&#10;END' />
      </column>
