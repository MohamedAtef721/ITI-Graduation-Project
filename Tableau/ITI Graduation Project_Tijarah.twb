            <column caption='Rank Direction' datatype='string' name='[Calculation_0761432619659264]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF RANK(SUM([LineTotal])) &lt; LOOKUP(RANK(SUM([LineTotal])), -1) THEN &#13;&#10;    &quot;Improved&quot;&#13;&#10;ELSEIF RANK(SUM([LineTotal])) &gt; LOOKUP(RANK(SUM([LineTotal])), -1) THEN &#13;&#10;    &quot;Declined&quot;&#13;&#10;ELSE &#13;&#10;    &quot;Unchanged&quot;&#13;&#10;END'>
