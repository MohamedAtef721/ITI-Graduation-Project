    <worksheet name='P4_BAN_Stock Value at Risk '>
      <layout-options>
        <caption>
          <formatted-text>
            <run>Stock Value at Risk </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='FactInventoryTransactions+ (SmartInventory_DWH)' name='federated.0o3jpeu10ur7xp1cywqy11o6zgvm' />
          </datasources>
          <datasource-dependencies datasource='federated.0o3jpeu10ur7xp1cywqy11o6zgvm'>
            <column caption='P4_Stock Value at Risk ' datatype='real' default-format='c&quot;$&quot;#,##0.0;(&quot;$&quot;#,##0.0)' name='[Calculation_0878256092946433]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [CurrentStock] &lt; [ReorderLevel] THEN ([ReorderLevel]-[CurrentStock])*[LastCostPrice] ELSE 0 END)' />
            </column>
            <column caption='P4_Stock Status' datatype='string' name='[Calculation_0878256132362249]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([CurrentStock]) = 0 THEN &quot;Out&quot;&#13;&#10;ELSEIF SUM([CurrentStock]) &lt; SUM([ReorderLevel]) THEN &quot;Below&quot;&#13;&#10;ELSEIF SUM([CurrentStock]) &gt; SUM([TargetStockLevel]) THEN &quot;Over&quot;&#13;&#10;ELSE &quot;OK&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='Current Stock' datatype='integer' name='[CurrentStock]' role='measure' type='quantitative' />
            <column caption='Full Date' datatype='date' name='[FullDate]' role='dimension' type='ordinal' />
            <column caption='Last Cost Price' datatype='real' name='[LastCostPrice]' role='measure' type='quantitative' />
            <column caption='Reorder Level' datatype='integer' name='[ReorderLevel]' role='measure' type='quantitative' />
            <column caption='Target Stock Level' datatype='integer' name='[TargetStockLevel]' role='measure' type='quantitative' />
            <column-instance column='[FullDate]' derivation='Month' name='[mn:FullDate:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0878256092946433]' derivation='User' name='[usr:Calculation_0878256092946433:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0878256132362249]' derivation='User' name='[usr:Calculation_0878256132362249:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[mn:FullDate:ok]' filter-group='9'>
            <groupfilter function='level-members' level='[mn:FullDate:ok]' />
          </filter>
          <filter class='categorical' column='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[none:Category:nk]' filter-group='8'>
            <groupfilter function='level-members' level='[none:Category:nk]' />
          </filter>
          <filter class='categorical' column='[federated.0o3jpeu10ur7xp1cywqy11o6zgvm].[usr:Calculation_0878256132362249:nk]'>
