  <MdxScripts>
    <MdxScript dwd:design-time-name="1325911b-7828-4420-8abf-546732ccfd8c">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].Qty_IN
 AS SUM(
    FILTER(
       [Dim Product].[Product Key] .Members,
        [Measures].[Quantity] &gt; 0
    ),
    [Measures].[Quantity]
), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].Qty_OUT
 AS -1*SUM(
    FILTER(
       [Dim Product].[Product Key] .Members,
        [Measures].[Quantity] &lt; 0
    ),
    [Measures].[Quantity]
), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].Net_Stock_Change
 AS [Measures].[Qty_IN] - [Measures].[Qty_OUT], 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>