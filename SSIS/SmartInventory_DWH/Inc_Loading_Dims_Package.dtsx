    <DTS:Executable
      DTS:refId="Package\Sequence Container Incremental Load DimDate"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Sequence Container"
      DTS:DTSID="{6EE3E7BD-EEA2-4D0F-8F28-E55C7436F84E}"
      DTS:ExecutableType="STOCK:SEQUENCE"
      DTS:LocaleID="-1"
      DTS:ObjectName="Sequence Container Incremental Load DimDate">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Sequence Container Incremental Load DimDate\Execute SQL Task"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{4E8346F4-0462-4CA2-8B01-3811D1A46F80}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{E6D9B83A-3F1E-4956-97CA-7EC0B27BE406}"
              SQLTask:SqlStatementSource="  &#xA;DECLARE @CurrentMaxDate DATE;&#xA;DECLARE @NewMaxDate DATE;&#xA;&#xA;-- آخر تاريخ موجود فعليًا في DimDate&#xA;SELECT @CurrentMaxDate = MAX(FullDate) FROM [SmartInventory_DWH].[dbo].[DimDate];&#xA;&#xA;-- احسبي أقصى تاريخ مطلوب من كل المصادر (نفس الـ query بتاعتك)&#xA;SELECT @NewMaxDate = MAX(d)&#xA;FROM&#xA;(&#xA;    SELECT MAX(AccountOpenedDate) AS d FROM [SmartInventory].[dbo].[Customers]&#xA;    UNION ALL SELECT MAX(OrderDate) FROM [SmartInventory].[dbo].[Orders]&#xA;    UNION ALL SELECT MAX(InvoiceDate) FROM [SmartInventory].[dbo].[Invoices]&#xA;    UNION ALL SELECT MAX(PurchaseOrderDate) FROM [SmartInventory].[dbo].[PurchaseOrders]&#xA;    UNION ALL SELECT MAX(TransactionDate) FROM [SmartInventory].[dbo].[CustomerTransactions]&#xA;    UNION ALL SELECT MAX(TransactionDate) FROM [SmartInventory].[dbo].[SupplierTransactions]&#xA;    UNION ALL SELECT MAX(CAST(TransactionDate AS DATE)) FROM [SmartInventory].[dbo].[InventoryTransactions]&#xA;) x;&#xA;&#xA;-- لو فيه تواريخ جديدة أكبر من اللي موجود، ضيفي الناقص بس&#xA;IF @NewMaxDate &gt; @CurrentMaxDate&#xA;BEGIN&#xA;    ;WITH DateSeries AS&#xA;    (&#xA;        SELECT DATEADD(DAY, 1, @CurrentMaxDate) AS FullDate&#xA;        UNION ALL&#xA;        SELECT DATEADD(DAY, 1, FullDate)&#xA;        FROM DateSeries&#xA;        WHERE FullDate &lt; @NewMaxDate&#xA;    )&#xA;    INSERT INTO [SmartInventory_DWH].[dbo].[DimDate] (DateKey, FullDate, DayNumber, DayName, MonthNumber, MonthName, &#xA;                          QuarterNumber, QuarterName, YearNumber, MonthYear, WeekNumber, IsWeekend)&#xA;    SELECT&#xA;        CONVERT(INT, FORMAT(FullDate,'yyyyMMdd')),&#xA;        FullDate,&#xA;        DAY(FullDate),&#xA;        DATENAME(WEEKDAY, FullDate),&#xA;        MONTH(FullDate),&#xA;        DATENAME(MONTH, FullDate),&#xA;        DATEPART(QUARTER, FullDate),&#xA;        'Q' + CAST(DATEPART(QUARTER, FullDate) AS VARCHAR(1)),&#xA;        YEAR(FullDate),&#xA;        CONCAT(YEAR(FullDate), '-', LEFT(DATENAME(MONTH, FullDate),3)),&#xA;        DATEPART(WEEK, FullDate),&#xA;        CASE WHEN DATENAME(WEEKDAY, FullDate) IN ('Friday','Saturday') THEN 1 ELSE 0 END&#xA;    FROM DateSeries&#xA;    OPTION (MAXRECURSION 0);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
