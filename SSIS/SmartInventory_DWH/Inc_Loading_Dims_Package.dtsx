          DTS:refId="Package\Sequence Container Inceremental Load for DimLoaction\Execute SQL Task handling Deleted city"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{7c17c764-2fef-4e62-bd52-701e2ed493c8}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task handling Deleted city"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{CCFF5FDC-DC89-4625-80EE-1DE4C1E68B70}"
              SQLTask:SqlStatementSource="    UPDATE DimLocation&#xA;SET IsCurrent = 0&#xA;WHERE IsCurrent = 1 &#xA;AND CityID NOT IN (SELECT CityID FROM [SmartInventory].[dbo].[Cities] )" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
