          DTS:LogicalAnd="True"
          DTS:ObjectName="Constraint 2"
          DTS:To="Package\Sequence Container Inceremental Load for DimLoaction\Execute SQL Task handling Deleted city" />
      </DTS:PrecedenceConstraints>
