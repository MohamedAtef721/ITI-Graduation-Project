                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    dd.DateKey,
    dp.ProductKey,
    dtt.TransactionTypeKey,

    it.InvoiceID,
    it.PurchaseOrderID,

    it.Quantity

FROM SmartInventory.dbo.InventoryTransactions it

INNER JOIN SmartInventory_DWH.dbo.DimDate dd
    ON CAST(it.TransactionDate AS DATE) = dd.FullDate

INNER JOIN SmartInventory_DWH.dbo.DimProduct dp
    ON it.ProductID = dp.ProductID

INNER JOIN SmartInventory_DWH.dbo.DimInventoryTransactionType dtt
    ON it.TransactionTypeID = dtt.TransactionTypeID
WHERE it.TransactionDate &gt; ?
;</property>
