                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    ct.TransactionDate,

    ct.CustomerID,
    NULL AS SupplierID,

    ct.InvoiceID,
    NULL AS PurchaseOrderID,

    ct.PaymentMethodID,
    ct.TransactionTypeID,

    N'Customer' AS TransactionSource,

    ct.NetAmount,
    ct.TaxAmount,

    ct.TransactionAmount,
    ct.RemainingBalance

FROM CustomerTransactions ct

UNION ALL

SELECT
    st.TransactionDate,

    NULL AS CustomerID,
    st.SupplierID,

    NULL AS InvoiceID,
    st.PurchaseOrderID,

    st.PaymentMethodID,
    st.TransactionTypeID,

    N'Supplier' AS TransactionSource,

    st.NetAmount,
    st.TaxAmount,

    st.TransactionAmount,
    st.RemainingBalance

FROM SupplierTransactions st;</property>
