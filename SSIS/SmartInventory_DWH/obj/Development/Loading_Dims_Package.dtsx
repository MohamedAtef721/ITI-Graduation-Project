            <component
              refId="Package\Dim_Date_Data Flow Task\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">DECLARE @MinDate DATE;
DECLARE @MaxDate DATE;

SELECT
    @MinDate = MIN(d),
    @MaxDate = MAX(d)
FROM
(
    SELECT MIN(AccountOpenedDate) AS d FROM Customers
    UNION ALL SELECT MIN(OrderDate) FROM Orders
    UNION ALL SELECT MIN(InvoiceDate) FROM Invoices
    UNION ALL SELECT MIN(PurchaseOrderDate) FROM PurchaseOrders
    UNION ALL SELECT MIN(TransactionDate) FROM CustomerTransactions
    UNION ALL SELECT MIN(TransactionDate) FROM SupplierTransactions
    UNION ALL SELECT MIN(CAST(TransactionDate AS DATE)) FROM InventoryTransactions

    UNION ALL

    SELECT MAX(AccountOpenedDate) FROM Customers
    UNION ALL SELECT MAX(OrderDate) FROM Orders
    UNION ALL SELECT MAX(InvoiceDate) FROM Invoices
    UNION ALL SELECT MAX(PurchaseOrderDate) FROM PurchaseOrders
    UNION ALL SELECT MAX(TransactionDate) FROM CustomerTransactions
    UNION ALL SELECT MAX(TransactionDate) FROM SupplierTransactions
    UNION ALL SELECT MAX(CAST(TransactionDate AS DATE)) FROM InventoryTransactions
) x;


WITH DateSeries AS
(
    SELECT @MinDate AS FullDate

    UNION ALL

    SELECT DATEADD(DAY,1,FullDate)
    FROM DateSeries
    WHERE FullDate &lt; @MaxDate
)

SELECT
    CONVERT(INT, FORMAT(FullDate,'yyyyMMdd')) AS DateKey,

    FullDate,

    DAY(FullDate) AS DayNumber,
    DATENAME(WEEKDAY, FullDate) AS DayName,

    MONTH(FullDate) AS MonthNumber,
    DATENAME(MONTH, FullDate) AS MonthName,

    DATEPART(QUARTER, FullDate) AS QuarterNumber,
    'Q' + CAST(DATEPART(QUARTER, FullDate) AS VARCHAR(1)) AS QuarterName,

    YEAR(FullDate) AS YearNumber,

    CONCAT(
        YEAR(FullDate),
        '-',
        LEFT(DATENAME(MONTH, FullDate),3)
    ) AS MonthYear,

    DATEPART(WEEK, FullDate) AS WeekNumber,

    CASE
        WHEN DATENAME(WEEKDAY, FullDate) IN ('Friday','Saturday')
        THEN 1
        ELSE 0
    END AS IsWeekend

FROM DateSeries
OPTION (MAXRECURSION 0);</property>
