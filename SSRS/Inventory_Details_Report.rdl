                      <UniqueName>[Dim Date].[Year Number].[Year Number]</UniqueName>
                    </ID>
                    <ItemCaption>Year Number</ItemCaption>
                    <UniqueName>true</UniqueName>
                  </Item>
                  <Item>
                    <ID xsi:type="Level">
