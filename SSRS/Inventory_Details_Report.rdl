  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="Param_Year">
            <Value>=Parameters!Param_Year.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="Param_Month">
            <Value>=Parameters!Param_Month.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="Param_Category">
            <Value>=Parameters!Param_Category.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    NON EMPTY { [Measures].[Net_Stock_Change], [Measures].[Qty_IN], [Measures].[Qty_OUT] } ON COLUMNS, 
    NON EMPTY { 
        (  [Dim Product].[Product].[Product].ALLMEMBERS * [Dim Transaction Type].[Transaction Type].[Transaction Type].ALLMEMBERS 
        ) 
    } DIMENSION PROPERTIES MEMBER_CAPTION, MEMBER_VALUE, MEMBER_UNIQUE_NAME ON ROWS 
FROM [Inventory_cube]
WHERE (StrToSet(@Param_Year), StrToSet(@Param_Month), StrToSet(@Param_Category))
CELL PROPERTIES VALUE, BACK_COLOR, FORE_COLOR, FORMATTED_VALUE, FORMAT_STRING, FONT_NAME, FONT_SIZE, FONT_FLAGS</CommandText>
        <rd:DesignerState>
          <QueryDefinition xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/AnalysisServices/QueryDefinition">
