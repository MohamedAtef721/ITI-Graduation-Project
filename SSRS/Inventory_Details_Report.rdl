                    <UniqueName>true</UniqueName>
                  </Item>
                  <Item>
                    <ID xsi:type="Measure">
                      <MeasureName>Net_Stock_Change</MeasureName>
                      <UniqueName>[Measures].[Net_Stock_Change]</UniqueName>
                    </ID>
                    <ItemCaption>Net_Stock_Change</ItemCaption>
                    <BackColor>true</BackColor>
                    <ForeColor>true</ForeColor>
                    <FontFamily>true</FontFamily>
