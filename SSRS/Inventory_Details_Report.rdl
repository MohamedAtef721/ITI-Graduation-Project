            </QuerySpecification>
            <Query>
              <Statement> SELECT NON EMPTY { [Measures].[Net_Stock_Change], [Measures].[Qty_IN], [Measures].[Qty_OUT] } ON COLUMNS, NON EMPTY { ([Dim Date].[Year Number].[Year Number].ALLMEMBERS * [Dim Date].[Month Name].[Month Name].ALLMEMBERS * [Dim Product].[Category].[Category].ALLMEMBERS * [Dim Product].[Product].[Product].ALLMEMBERS * [Dim Transaction Type].[Transaction Type].[Transaction Type].ALLMEMBERS ) } DIMENSION PROPERTIES MEMBER_CAPTION, MEMBER_VALUE, MEMBER_UNIQUE_NAME ON ROWS FROM [Inventory_cube] CELL PROPERTIES VALUE, BACK_COLOR, FORE_COLOR, FORMATTED_VALUE, FORMAT_STRING, FONT_NAME, FONT_SIZE, FONT_FLAGS</Statement>
