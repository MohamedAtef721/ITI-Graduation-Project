          <QueryParameter Name="Param_Customer">
            <Value>=Parameters!Param_Customer.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
NON EMPTY { [Measures].[Total_Revenue], [Measures].[Total_Profit], [Measures].[Unit Price], [Measures].[Quantity], [Measures].[Profit Amount], [Measures].[Avg_Revenue_Per_Invoice], [Measures].[Profit_Margin_Percentage] } ON COLUMNS, 
NON EMPTY { 
    ( [Dim Customer].[Customer Name].[Customer Name].ALLMEMBERS * [Dim Date].[Month Number].[Month Number].ALLMEMBERS * [Dim Delivery Method].[Delivery Method].[Delivery Method].ALLMEMBERS * [Dim Employee].[Full Name].[Full Name].ALLMEMBERS * [Dim Location].[City].[City].ALLMEMBERS * [Dim Product].[Product].[Product].ALLMEMBERS * [Dim Product].[Category].[Category].ALLMEMBERS ) 
} DIMENSION PROPERTIES MEMBER_CAPTION, MEMBER_VALUE, MEMBER_UNIQUE_NAME ON ROWS 
FROM [Sales_cubes]
WHERE (StrToSet(@Param_Year),StrToSet(@Param_Month),StrToSet(@Param_Customer))</CommandText>
