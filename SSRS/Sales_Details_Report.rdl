    <DataSet Name="DS_Customer_Category">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>WITH MEMBER [Measures].[CatUniqueName] AS 
     [Dim Customer].[Customer Category].CurrentMember.UniqueName
SELECT 
     { [Measures].[CatUniqueName] } ON COLUMNS,
     [Dim Customer].[Customer Category].[Customer Category].MEMBERS ON ROWS
FROM [Sales_cubes]</CommandText>
        <rd:DesignerState>
          <QueryDefinition xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/AnalysisServices/QueryDefinition">
